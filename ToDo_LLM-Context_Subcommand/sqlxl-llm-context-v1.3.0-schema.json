{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sqlxl.example/schemas/llm-context-v1.json",
  "title": "sqlxl llm-context output (format_version 1)",
  "description": "Schema for the JSON output of `sqlxl llm-context --format json`. Treat this as a versioned contract — additive changes do not bump format_version; removing/renaming fields does.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format_version",
    "sqlxl_version",
    "generated_at",
    "summary",
    "connection_model",
    "commands",
    "template_structure",
    "bulk_op_feature_schema",
    "agent_best_practices",
    "workflows",
    "gotchas",
    "builtin_schema"
  ],
  "properties": {
    "format_version": {
      "type": "integer",
      "const": 1,
      "description": "Schema version. Bumped on breaking changes to this contract."
    },
    "sqlxl_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[A-Za-z0-9.-]+)?$",
      "description": "Installed sqlxl binary version (semver)."
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 UTC timestamp of when this document was emitted."
    },
    "docs_url": {
      "type": "string",
      "format": "uri",
      "description": "Canonical docs URL for this version (optional)."
    },
    "summary": {
      "type": "string",
      "description": "One-paragraph mental model of the tool. <= 500 chars recommended."
    },
    "connection_model": { "$ref": "#/$defs/connection_model" },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/command" }
    },
    "template_structure": { "$ref": "#/$defs/template_structure" },
    "bulk_op_feature_schema": {
      "type": "array",
      "minItems": 1,
      "description": "Columns of SqlXl.BulkOpFeatures.",
      "items": { "$ref": "#/$defs/db_column" }
    },
    "agent_best_practices": {
      "type": "array",
      "items": { "$ref": "#/$defs/best_practice" }
    },
    "workflows": {
      "type": "array",
      "items": { "$ref": "#/$defs/workflow" }
    },
    "gotchas": {
      "type": "array",
      "items": { "type": "string" }
    },
    "builtin_schema": {
      "type": "array",
      "description": "Tables installed by `sqlxl init` into the SqlXl schema.",
      "items": { "$ref": "#/$defs/builtin_table" }
    },
    "active_state": {
      "$ref": "#/$defs/active_state",
      "description": "Present only when --include-state was passed and a profile is active."
    }
  },

  "$defs": {

    "connection_model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["override_flags"],
      "properties": {
        "profile_storage_path": {
          "type": "string",
          "description": "Absolute path on the host where saved profiles live."
        },
        "default_profile_name": {
          "type": "string",
          "description": "Profile name used by `init` when --profile is omitted.",
          "default": "default"
        },
        "override_flags": {
          "type": "array",
          "items": { "$ref": "#/$defs/flag" },
          "description": "Flags every operational command accepts to override the active profile (typically --connection and --profile)."
        }
      }
    },

    "command": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "summary", "synopses", "flags"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*( [a-z][a-z0-9-]*)*$",
          "description": "Command name, e.g. `insert` or `connections list`."
        },
        "summary": {
          "type": "string",
          "description": "One-line description."
        },
        "synopses": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" },
          "description": "USAGE lines, e.g. `sqlxl insert --table <T> [--no-launch]`."
        },
        "flags": {
          "type": "array",
          "items": { "$ref": "#/$defs/flag" }
        },
        "positional_args": {
          "type": "array",
          "items": { "$ref": "#/$defs/positional_arg" }
        },
        "behaviors": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Non-obvious behaviors. The most valuable field for AI consumers — capture side effects, prerequisites, and surprises."
        },
        "prerequisites": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Other commands that must run first (e.g. `init` for `export`)."
        },
        "examples": {
          "type": "array",
          "items": { "$ref": "#/$defs/example" }
        },
        "subcommands": {
          "type": "array",
          "items": { "$ref": "#/$defs/command" },
          "description": "Nested subcommands (e.g. `connections list`, `connections remove`)."
        },
        "destructive": {
          "type": "boolean",
          "default": false,
          "description": "True if the command mutates data destructively (e.g. `demo` drops a database)."
        }
      }
    },

    "flag": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "description"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^(-[a-zA-Z]|--[a-z][a-z0-9-]*)$"
        },
        "aliases": {
          "type": "array",
          "items": { "type": "string", "pattern": "^(-[a-zA-Z]|--[a-z][a-z0-9-]*)$" }
        },
        "value_type": {
          "type": "string",
          "enum": ["string", "int", "float", "bool", "path", "connection_string", "sql", "enum"],
          "description": "Type of the flag's value. Use `bool` for boolean switches like --no-launch, --yes."
        },
        "value_placeholder": {
          "type": "string",
          "description": "Display name for the value, e.g. `<CONNSTR>`, `<PATH>`."
        },
        "enum_values": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Required when value_type is `enum`."
        },
        "default": {
          "description": "Default value if flag is omitted. Type matches value_type."
        },
        "required": {
          "type": "boolean",
          "default": false
        },
        "description": {
          "type": "string"
        },
        "scope": {
          "type": "string",
          "enum": ["template_generation", "import", "always"],
          "default": "always",
          "description": "When the flag applies. `update --where` is `template_generation` only."
        }
      },
      "allOf": [
        {
          "if": { "properties": { "value_type": { "const": "enum" } }, "required": ["value_type"] },
          "then": { "required": ["enum_values"] }
        }
      ]
    },

    "positional_arg": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "description"],
      "properties": {
        "name": { "type": "string" },
        "value_type": {
          "type": "string",
          "enum": ["string", "path", "identifier"]
        },
        "required": { "type": "boolean", "default": true },
        "description": { "type": "string" }
      }
    },

    "example": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command"],
      "properties": {
        "command": { "type": "string", "description": "Literal shell invocation." },
        "comment": { "type": "string", "description": "What this example demonstrates." }
      }
    },

    "template_structure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sheets", "fk_label_format"],
      "properties": {
        "sheets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "purpose", "columns"],
            "properties": {
              "name": { "type": "string", "description": "Exact sheet name in the workbook." },
              "purpose": { "type": "string" },
              "columns": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Column header names in order. Empty array if dynamic (e.g. Data sheet whose columns depend on the table)."
              },
              "dynamic_columns": {
                "type": "boolean",
                "default": false,
                "description": "True when columns vary per table/feature (e.g. the Data sheet)."
              }
            }
          }
        },
        "fk_label_format": {
          "type": "string",
          "description": "Exact format used in DropdownOptions for FK values, e.g. `<id> - <label>`."
        },
        "column_aliasing_syntax": {
          "type": "string",
          "description": "Syntax used in GetRowsToEdit_SelectStatement to alias DB columns to Excel headers, e.g. `[DbCol|ExcelHeader]`."
        },
        "identity_pk_excluded_from_data_sheet": {
          "type": "boolean",
          "description": "True if Insert templates omit IDENTITY/PK columns from the Data sheet."
        }
      }
    },

    "db_column": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "sql_type"],
      "properties": {
        "name": { "type": "string" },
        "sql_type": {
          "type": "string",
          "description": "SQL Server data type, e.g. `int`, `nvarchar(max)`, `bit`."
        },
        "nullable": { "type": "boolean", "default": true },
        "is_primary_key": { "type": "boolean", "default": false },
        "description": { "type": "string" }
      }
    },

    "best_practice": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rule", "rationale"],
      "properties": {
        "rule": { "type": "string", "description": "What to do (or not do)." },
        "rationale": { "type": "string", "description": "Why — what breaks if you ignore the rule." },
        "applies_to": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Command names this rule applies to. Empty array = global."
        }
      }
    },

    "workflow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "title", "steps"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Stable identifier, e.g. `round_trip_insert`."
        },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["action"],
            "properties": {
              "action": {
                "type": "string",
                "enum": ["command", "manual"],
                "description": "`command` = literal shell invocation, `manual` = human action between commands (e.g. 'edit the file')."
              },
              "command": { "type": "string", "description": "Required when action='command'." },
              "instruction": { "type": "string", "description": "Required when action='manual'." },
              "comment": { "type": "string" }
            }
          }
        }
      }
    },

    "builtin_table": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "name", "purpose"],
      "properties": {
        "schema": { "type": "string", "default": "SqlXl" },
        "name": { "type": "string" },
        "purpose": { "type": "string" },
        "is_staging_template": {
          "type": "boolean",
          "default": false,
          "description": "True for the `Staging_<Name>` pattern (one created per feature, not a fixed table)."
        }
      }
    },

    "active_state": {
      "type": "object",
      "additionalProperties": false,
      "description": "Runtime snapshot, present only with --include-state.",
      "required": ["profile", "configured_features"],
      "properties": {
        "profile": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "server", "database"],
          "properties": {
            "name": { "type": "string" },
            "server": { "type": "string" },
            "database": { "type": "string" }
          }
        },
        "configured_features": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "name", "type", "domain_table"],
            "properties": {
              "id": { "type": "integer" },
              "name": { "type": "string" },
              "type": {
                "type": "string",
                "enum": ["Insert", "Update", "Delete", "Custom"]
              },
              "domain_table": { "type": "string", "description": "schema.table" },
              "staging_table": { "type": "string" },
              "sproc": { "type": "string" }
            }
          }
        },
        "domain_tables": {
          "type": "array",
          "items": { "type": "string", "description": "schema.table" }
        }
      }
    }
  }
}
